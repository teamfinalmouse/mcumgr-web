{
  "name": "mcumgr-web",
  "version": "0.3.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "pkg": {
    "assets": [
      "node_modules/@serialport/bindings-cpp/prebuilds/**/*"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "bin": {
    "mcumgr-web": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:bundle": "esbuild src/index.ts --bundle --outfile=dist/mcumgr-web.js --format=esm --minify --platform=browser && esbuild src/global.ts --bundle --outfile=dist/mcumgr-web.iife.js --format=iife --minify --platform=browser",
    "build:all": "npm run build && npm run build:bundle",
    "cli": "node dist/cli.js",
    "package": "npm run build && npx @yao-pkg/pkg . --targets node22-linux-x64,node22-win-x64 --output mcumgr-web",
    "package:linux": "npm run build && npx @yao-pkg/pkg . --targets node22-linux-x64 --output mcumgr-web-linux",
    "package:win": "npm run build && npx @yao-pkg/pkg . --targets node22-win-x64 --output mcumgr-web-win.exe",
    "prepare": "npm run build",
    "test": "vitest run tests/unit/",
    "test:device": "vitest run tests/device/",
    "test:all": "vitest run tests/"
  },
  "dependencies": {
    "cbor-x": "^1.6",
    "commander": "^13.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/w3c-web-hid": "^1.0.6",
    "@types/w3c-web-serial": "^1.0.7",
    "esbuild": "^0.24",
    "node-hid": "^3.1",
    "serialport": "^12.0.0",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
